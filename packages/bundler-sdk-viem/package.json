{
  "name": "@morpho-org/bundler-sdk-viem",
  "description": "Viem-based extension of `@morpho-org/simulation-sdk` that exports utilities to transform simple interactions on Morpho (such as `Blue_Borrow`) and Morpho Vaults (such as `MetaMorpho_Deposit`) into the required bundles (with ERC20 approvals, transfers, etc) to submit to the bundler onchain.",
  "version": "5.0.3",
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Rubilmax <rmilon@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morpho-org/sdks.git",
    "directory": "packages/bundler-sdk-viem"
  },
  "homepage": "https://github.com/morpho-org/sdks",
  "bugs": {
    "url": "https://github.com/morpho-org/sdks/issues",
    "email": "contact@morpho.org"
  },
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "DEPRECATION.md",
    "lib"
  ],
  "scripts": {
    "prepublish": "$npm_execpath build",
    "build": "$npm_execpath build:cjs && $npm_execpath build:esm",
    "build:cjs": "tsc --build tsconfig.build.cjs.json && echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json",
    "build:esm": "tsc --build tsconfig.build.esm.json && echo '{\"type\":\"module\"}' > lib/esm/package.json"
  },
  "peerDependencies": {
    "@morpho-org/blue-sdk": "catalog:",
    "@morpho-org/blue-sdk-viem": "catalog:",
    "@morpho-org/morpho-ts": "catalog:",
    "@morpho-org/simulation-sdk": "catalog:",
    "viem": "catalog:peer"
  },
  "devDependencies": {
    "@morpho-org/blue-sdk": "workspace:^",
    "@morpho-org/blue-sdk-viem": "workspace:^",
    "@morpho-org/morpho-test": "workspace:^",
    "@morpho-org/morpho-ts": "workspace:^",
    "@morpho-org/simulation-sdk": "workspace:^",
    "@morpho-org/simulation-sdk-wagmi": "workspace:^",
    "@morpho-org/test": "workspace:^",
    "@morpho-org/test-wagmi": "workspace:^",
    "@tanstack/query-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/lodash": "catalog:",
    "lodash": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./lib/esm/index.d.ts",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
      }
    }
  }
}
