{
  "name": "@morpho-org/wdk-protocol-lending-morpho-evm",
  "version": "1.0.0-beta.1",
  "description": "A WDK lending module that lets EVM wallet accounts interact with Morpho vaults and markets through @morpho-org/morpho-sdk.",
  "keywords": [
    "wdk",
    "protocol",
    "lending",
    "vaults",
    "morpho",
    "morpho-sdk",
    "morpho blue",
    "ethereum",
    "erc-4337"
  ],
  "author": "Morpho Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/morpho-org/wdk-protocol-lending-morpho-evm.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build": "pnpm run build:types",
    "build:types": "tsc",
    "check:vault-v2": "node scripts/check-vault-v2-only.js",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "pretest": "pnpm run check:vault-v2",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:fork": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration/module.test.js",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@morpho-org/blue-sdk": "5.23.2",
    "@morpho-org/blue-sdk-viem": "4.6.5",
    "@morpho-org/morpho-sdk": "1.2.1",
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.11",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.6",
    "bare-node-runtime": "^1.1.4",
    "viem": "^2.48.1"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "jest": "29.7.0",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "overrides": {
    "@gelatonetwork/relay-sdk": {
      "axios": "^1.15.0"
    }
  },
  "files": [
    "index.js",
    "bare.js",
    "src/",
    "scripts/",
    "types/",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22.13.0"
  }
}
