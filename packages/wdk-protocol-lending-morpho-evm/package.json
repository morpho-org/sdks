{
  "name": "@morpho-org/wdk-protocol-lending-morpho-evm",
  "version": "0.0.6",
  "description": "A WDK lending module that lets EVM wallet accounts interact with Morpho vaults and markets through @morpho-org/morpho-sdk.",
  "keywords": [
    "wdk",
    "protocol",
    "lending",
    "vaults",
    "morpho",
    "morpho-sdk",
    "morpho blue",
    "ethereum",
    "erc-4337"
  ],
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Morpho Labs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morpho-org/sdks.git",
    "directory": "packages/wdk-protocol-lending-morpho-evm"
  },
  "homepage": "https://github.com/morpho-org/sdks",
  "bugs": {
    "url": "https://github.com/morpho-org/sdks/issues",
    "email": "contact@morpho.org"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "lib",
    "bare.js",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "./bare.js"
  ],
  "scripts": {
    "check:vault-v2": "node scripts/check-vault-v2-only.js",
    "prepublish": "$npm_execpath build",
    "build": "pnpm run check:vault-v2 && $npm_execpath build:cjs && $npm_execpath build:esm",
    "build:cjs": "tsc --build tsconfig.build.cjs.json --noCheck && echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json",
    "build:esm": "tsc --build tsconfig.build.esm.json --noCheck && echo '{\"type\":\"module\"}' > lib/esm/package.json",
    "pretest": "pnpm run check:vault-v2",
    "test": "vitest --root ../.. --project wdk-protocol-lending-morpho-evm"
  },
  "dependencies": {
    "@morpho-org/blue-sdk": "workspace:^",
    "@morpho-org/blue-sdk-viem": "workspace:^",
    "@morpho-org/morpho-sdk": "workspace:^",
    "@tetherto/wdk-wallet": "1.0.0-beta.11",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.14",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.9",
    "bare-node-runtime": "1.5.0"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "viem": "^2.53.1",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./lib/esm/index.d.ts",
        "bare": "./bare.js",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
      },
      "./package": {
        "default": "./package.json"
      }
    }
  },
  "engines": {
    "node": ">=22.13"
  }
}
