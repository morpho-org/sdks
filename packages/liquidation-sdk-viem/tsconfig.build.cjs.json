{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "outDir": "./lib/cjs",
    "tsBuildInfoFile": "tsconfig.cjs.tsbuildinfo"
  },
  "include": ["src"],
  "files": [],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/**/__test__/**",
    "src/**/__mocks__/**",
    "src/**/__fixtures__/**"
  ]
}
