{
  "name": "@morpho-org/test",
  "description": "Viem-based package that exports utilities to build Vitest & Playwright fixtures that spawn anvil forks as child processes.",
  "version": "2.8.1",
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Rubilmax <rmilon@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morpho-org/sdks.git",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/morpho-org/sdks",
  "bugs": {
    "url": "https://github.com/morpho-org/sdks/issues",
    "email": "contact@morpho.org"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "lib"
  ],
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vitest": "./src/vitest.ts",
    "./fixtures": "./src/fixtures.ts",
    "./mock": "./src/mock.ts",
    "./playwright": "./src/playwright.ts"
  },
  "typesVersions": {
    "*": {
      "vitest": [
        "src/vitest.ts"
      ],
      "fixtures": [
        "src/fixtures.ts"
      ],
      "mock": [
        "src/mock.ts"
      ],
      "playwright": [
        "src/playwright.ts"
      ]
    }
  },
  "scripts": {
    "prepublish": "$npm_execpath build",
    "build": "$npm_execpath build:cjs && $npm_execpath build:esm",
    "build:cjs": "tsc --build tsconfig.build.cjs.json && echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json",
    "build:esm": "tsc --build tsconfig.build.esm.json && echo '{\"type\":\"module\"}' > lib/esm/package.json"
  },
  "dependencies": {
    "lodash.kebabcase": "^4.1.1",
    "viem-deal": "^2.0.4",
    "viem-tracer": "^1.8.0"
  },
  "peerDependencies": {
    "@playwright/test": "^1.48.1",
    "viem": "catalog:test-peer",
    "vitest": "catalog:test-peer"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/lodash.kebabcase": "^4.1.9",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./lib/esm/index.d.ts",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
      },
      "./vitest": {
        "types": "./lib/esm/vitest.d.ts",
        "import": "./lib/esm/vitest.js",
        "require": "./lib/cjs/vitest.js"
      },
      "./fixtures": {
        "types": "./lib/esm/fixtures.d.ts",
        "import": "./lib/esm/fixtures.js",
        "require": "./lib/cjs/fixtures.js"
      },
      "./mock": {
        "types": "./lib/esm/mock.d.ts",
        "import": "./lib/esm/mock.js"
      },
      "./playwright": {
        "types": "./lib/esm/playwright.d.ts",
        "import": "./lib/esm/playwright.js",
        "require": "./lib/cjs/playwright.js"
      }
    }
  }
}
