{
  "name": "@morpho-org/liquidity-sdk-viem",
  "description": "Viem-based package that helps seamlessly calculate the liquidity available through the PublicAllocator.",
  "version": "1.4.1",
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Rubilmax <rmilon@gmail.com>"
  ],
  "license": "MIT",
  "repository": "github:morpho-org/sdks",
  "homepage": "https://github.com/morpho-org/sdks",
  "bugs": {
    "url": "https://github.com/morpho-org/sdks/issues",
    "email": "contact@morpho.org"
  },
  "main": "src/index.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "prepublish": "$npm_execpath build",
    "build": "tsc --noEmit && $npm_execpath build:cjs && $npm_execpath build:esm",
    "build:cjs": "tsc --build tsconfig.build.cjs.json && echo '{\"type\":\"commonjs\"}' > lib/cjs/package.json",
    "build:esm": "tsc --build tsconfig.build.esm.json && echo '{\"type\":\"module\"}' > lib/esm/package.json",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "peerDependencies": {
    "@morpho-org/blue-sdk": "workspace:^",
    "@morpho-org/blue-sdk-viem": "workspace:^",
    "@morpho-org/morpho-ts": "workspace:^",
    "@morpho-org/morpho-sdk": "workspace:^",
    "dataloader": "^2.2.3",
    "graphql": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "graphql-request": "^6.1.0",
    "graphql-tag": "^2.12.6",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/import-types-preset": "^4.0.1",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@morpho-org/blue-sdk": "workspace:^",
    "@morpho-org/blue-sdk-viem": "workspace:^",
    "@morpho-org/morpho-test": "workspace:^",
    "@morpho-org/morpho-ts": "workspace:^",
    "@morpho-org/morpho-sdk": "workspace:^",
    "@morpho-org/test": "workspace:^",
    "graphql": "^16.14.0",
    "nock": "^14.0.15",
    "typescript": "^6.0.3",
    "viem": "^2.49.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./lib/esm/index.d.ts",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
      }
    }
  },
  "type": "module"
}
